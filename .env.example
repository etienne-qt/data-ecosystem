# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DEV_QUEBECTECH
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=

# HubSpot
HUBSPOT_ACCESS_TOKEN=

# Asana (OAuth2 — preferred)
ASANA_CLIENT_ID=                   # From Asana Developer Console
ASANA_CLIENT_SECRET=               # From Asana Developer Console
ASANA_OAUTH_TOKEN_FILE=            # Where to store the token (default: ~/.config/ecosystem/asana_token.json)

# Asana (PAT — alternative to OAuth2)
ASANA_ACCESS_TOKEN=                # Personal Access Token (if not using OAuth2)

# Asana project config
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=                 # Default project for agent tasks

# Google (OAuth2 — preferred)
GOOGLE_OAUTH_CLIENT_FILE=          # Path to OAuth2 client secrets JSON (from Google Cloud Console)
GOOGLE_OAUTH_TOKEN_FILE=           # Where to store the token (default: ~/.config/ecosystem/google_token.json)

# Google (service account — legacy, used as fallback if no OAuth2)
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DOCS_FOLDER_ID=

# ChromaDB
CHROMADB_PATH=./knowledge_base/.chromadb

# LLM (optional, for startup classifier)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://127.0.0.1:11434
