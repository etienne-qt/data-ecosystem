# Local data — never publish. Contains raw exports, session logs,
# messages, meeting notes, downloaded report PDFs, and any record-level
# licensed data pulled from Snowflake. The README explaining this
# directory is tracked so new contributors can see the conventions.
data/*
!data/README.md
logs/
notebooks/

# Local-only QT operational content (archived legacy code).
# Removed from git tracking, kept on disk for reference.
archive/

# Third-party sandbox (Google Apps Script project, separate scope).
GoogleAppScripts/

# Spreadsheet exports (commit public CSVs only via public-data/).
*.csv
*.xlsx
*.xls

